{
  "name": "homemade-native-challenge",
  "private": true,
  "version": "0.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "postinstall": "node scripts/patch-expo-modules-jsi.cjs",
    "start": "expo start",
    "dev:app": "expo start",
    "dev:backend": "cd backend && npm run dev",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "typecheck:backend": "cd backend && npm run typecheck",
    "lint": "expo lint"
  },
  "dependencies": {
    "@shopify/flash-list": "2.0.2",
    "@shopify/react-native-skia": "2.6.2",
    "expo": "57.0.2",
    "expo-blur": "57.0.0",
    "expo-constants": "57.0.3",
    "expo-dev-client": "~57.0.5",
    "expo-file-system": "~57.0.0",
    "expo-font": "^57.0.0",
    "expo-haptics": "57.0.0",
    "expo-image-manipulator": "~57.0.2",
    "expo-image-picker": "~57.0.2",
    "expo-linking": "57.0.1",
    "expo-router": "57.0.3",
    "expo-status-bar": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-svg": "15.15.4",
